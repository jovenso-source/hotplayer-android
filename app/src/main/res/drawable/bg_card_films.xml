<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <solid android:color="#1a0008"/>
            <corners android:radius="18dp"/>
        </shape>
    </item>
    <item>
        <shape>
            <gradient
                android:startColor="#6a0028"
                android:endColor="#050005"
                android:angle="315"
                android:type="linear"/>
            <corners android:radius="18dp"/>
        </shape>
    </item>
    <item android:top="60dp" android:bottom="0dp" android:left="0dp" android:right="60dp">
        <shape>
            <gradient
                android:startColor="#9a0040"
                android:endColor="#00000000"
                android:angle="45"
                android:type="linear"/>
            <corners android:radius="18dp"/>
        </shape>
    </item>
</layer-list>
