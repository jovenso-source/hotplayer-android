<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape>
            <solid android:color="#161c28"/>
            <stroke android:width="2dp" android:color="#ff4d00"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#1e2436"/>
            <stroke android:width="2dp" android:color="#ff7340"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="#131720"/>
            <stroke android:width="1dp" android:color="#1e2436"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>
</selector>
