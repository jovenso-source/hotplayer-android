<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">
    <LinearLayout
        android:id="@+id/screenLoading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="visible">
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="48dp">
            <TextView
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:gravity="center"
                android:text="▶"
                android:textSize="22sp"
                android:textColor="@color/white"
                android:background="@drawable/bg_logo_icon"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:text="FreeBox"
                android:textSize="36sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"/>
        </LinearLayout>
        <ProgressBar
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:indeterminateTint="@color/accent"
            android:layout_marginBottom="20dp"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Vérification de votre appareil…"
            android:textSize="16sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="24dp"/>
        <LinearLayout
            android:layout_width="320dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VOTRE IDENTIFIANT"
                android:textSize="12sp"
                android:textColor="@color/text_tertiary"
                android:layout_marginBottom="6dp"/>
            <TextView
                android:id="@+id/macValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Détection…"
                android:textSize="18sp"
                android:textColor="@color/accent_light"/>
        </LinearLayout>
    </LinearLayout>
    <ScrollView
        android:id="@+id/screenNotActivated"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="60dp">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="40dp">
                <TextView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:gravity="center"
                    android:text="▶"
                    android:textSize="18sp"
                    android:textColor="@color/white"
                    android:background="@drawable/bg_logo_icon"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="FreeBox"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"/>
            </LinearLayout>
            <LinearLayout
                android:layout_width="420dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="28dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚠  Appareil non activé"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="12dp"/>
                <TextView
                    android:id="@+id/statusMessage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Contactez votre administrateur."
                    android:textSize="14sp"
                    android:textColor="@color/red"
                    android:background="@drawable/bg_error_pill"
                    android:padding="12dp"
                    android:layout_marginBottom="20dp"/>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_mac_box"
                    android:padding="14dp"
                    android:layout_marginBottom="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="VOTRE IDENTIFIANT"
                        android:textSize="12sp"
                        android:textColor="@color/text_tertiary"
                        android:layout_marginBottom="6dp"/>
                    <TextView
                        android:id="@+id/macValue2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textSize="20sp"
                        android:textColor="@color/accent_light"/>
                </LinearLayout>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Communiquez cette adresse à votre administrateur."
                    android:textSize="12sp"
                    android:textColor="@color/text_tertiary"
                    android:layout_marginBottom="24dp"/>
                <Button
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="↻  Réessayer"
                    android:textColor="@color/white"
                    android:backgroundTint="@color/accent"
                    android:onClick="onRetryClick"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</FrameLayout>
