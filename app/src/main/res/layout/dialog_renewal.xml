<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CC000000">

    <ScrollView
        android:layout_width="560dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/renewalCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_popup_card"
            android:padding="28dp">

            <!-- Header : icône priorité + titre -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <TextView
                    android:id="@+id/tvRenewalIcon"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:gravity="center"
                    android:textSize="20sp"
                    android:background="@drawable/bg_logo_icon"
                    android:layout_marginEnd="14dp"
                    android:text="⚠"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvRenewalBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:letterSpacing="0.10"
                        android:background="@drawable/bg_live_badge"
                        android:paddingHorizontal="7dp"
                        android:paddingVertical="2dp"
                        android:layout_marginBottom="5dp"
                        android:text="RENOUVELLEMENT"/>

                    <TextView
                        android:id="@+id/tvRenewalTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:text="Abonnement bientôt expiré"/>

                </LinearLayout>
            </LinearLayout>

            <!-- Message -->
            <TextView
                android:id="@+id/tvRenewalMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:lineSpacingMultiplier="1.4"
                android:layout_marginBottom="20dp"/>

            <!-- Infos abonnement -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_search_field"
                android:padding="14dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PLAN"
                        android:textSize="11sp"
                        android:textColor="@color/text_tertiary"
                        android:letterSpacing="0.08"/>

                    <TextView
                        android:id="@+id/tvRenewalPlan"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginTop="3dp"/>

                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="@color/border"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="EXPIRATION"
                        android:textSize="11sp"
                        android:textColor="@color/text_tertiary"
                        android:letterSpacing="0.08"/>

                    <TextView
                        android:id="@+id/tvRenewalExpiry"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/yellow"
                        android:layout_marginTop="3dp"/>

                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="@color/border"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="JOURS"
                        android:textSize="11sp"
                        android:textColor="@color/text_tertiary"
                        android:letterSpacing="0.08"/>

                    <TextView
                        android:id="@+id/tvRenewalDays"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/accent_light"
                        android:layout_marginTop="3dp"/>

                </LinearLayout>
            </LinearLayout>

            <!-- Identifiant appareil -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_mac_box"
                android:padding="14dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="IDENTIFIANT APPAREIL"
                    android:textSize="11sp"
                    android:textColor="@color/text_tertiary"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:id="@+id/tvRenewalDeviceId"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textColor="@color/accent_light"
                    android:fontFamily="monospace"
                    android:textIsSelectable="false"/>

            </LinearLayout>

            <!-- Boutons TV-safe : D-Pad friendly, grands, focusables -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Copier l'identifiant -->
                <Button
                    android:id="@+id/btnRenewalCopyId"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:backgroundTint="@color/bg_tertiary"
                    android:focusable="true"
                    android:focusableInTouchMode="false"
                    android:nextFocusDown="@id/btnRenewalContact"
                    android:nextFocusUp="@id/btnRenewalDismiss"
                    android:layout_marginBottom="8dp"
                    android:text="Copier l'identifiant"/>

                <!-- Contacter l'administrateur (masqué si pas de contact) -->
                <Button
                    android:id="@+id/btnRenewalContact"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:textSize="15sp"
                    android:textColor="#1a1200"
                    android:backgroundTint="@color/accent"
                    android:textStyle="bold"
                    android:focusable="true"
                    android:focusableInTouchMode="false"
                    android:nextFocusDown="@id/btnRenewalDismiss"
                    android:nextFocusUp="@id/btnRenewalCopyId"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone"
                    android:text="Contacter l'administrateur"/>

                <!-- Plus tard / Fermer -->
                <Button
                    android:id="@+id/btnRenewalDismiss"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:backgroundTint="#1e2235"
                    android:focusable="true"
                    android:focusableInTouchMode="false"
                    android:nextFocusDown="@id/btnRenewalCopyId"
                    android:nextFocusUp="@id/btnRenewalContact"
                    android:visibility="gone"
                    android:text="Plus tard"/>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</FrameLayout>
