<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="210dp"
    android:layout_height="135dp"
    android:layout_marginEnd="12dp"
    android:focusable="true"
    android:clickable="true"
    android:background="@drawable/bg_live_card">

    <!-- Red left accent bar -->
    <View
        android:layout_width="3dp"
        android:layout_height="match_parent"
        android:background="#e53935"/>

    <!-- Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="12dp"
        android:paddingStart="15dp">

        <!-- League + LIVE badge row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <ImageView
                android:id="@+id/ivLeagueLogo"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginEnd="5dp"
                android:scaleType="fitCenter"/>

            <TextView
                android:id="@+id/tvLeagueName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="10sp"
                android:textColor="#6b7894"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● LIVE"
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="#e53935"
                android:paddingHorizontal="5dp"
                android:paddingVertical="2dp"
                android:background="#1ae53935"/>
        </LinearLayout>

        <!-- Teams row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Home team -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <ImageView
                    android:id="@+id/ivHomeLogo"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:scaleType="fitCenter"/>

                <TextView
                    android:id="@+id/tvHomeTeam"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="#e2e8f0"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:gravity="center"/>
            </LinearLayout>

            <!-- Score -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingHorizontal="8dp">

                <TextView
                    android:id="@+id/tvScore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:fontFamily="monospace"
                    android:text="0 - 0"/>

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textSize="9sp"
                    android:textColor="#e53935"
                    android:textStyle="bold"
                    android:text="45'"/>
            </LinearLayout>

            <!-- Away team -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <ImageView
                    android:id="@+id/ivAwayLogo"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:scaleType="fitCenter"/>

                <TextView
                    android:id="@+id/tvAwayTeam"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="#e2e8f0"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:gravity="center"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Focus border -->
    <View
        android:id="@+id/viewFocusBorder"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_sport_card_focused"
        android:visibility="gone"/>
</FrameLayout>
