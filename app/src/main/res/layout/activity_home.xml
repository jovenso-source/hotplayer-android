<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0a0d14"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- ══════════ HEADER ══════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingLeft="40dp"
        android:paddingRight="36dp">

        <!-- App name: "Free" regular + "BOX" bold -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Free"
                android:textSize="22sp"
                android:textColor="#FFFFFF"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BOX"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"/>
        </LinearLayout>

        <!-- Vertical divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="22dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="16dp"
            android:background="#1a2035"/>

        <!-- Mic button (circle) -->
        <LinearLayout
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:background="@drawable/bg_home_circle_btn"
            android:layout_marginEnd="10dp"
            android:focusable="false">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎙"
                android:textSize="15sp"/>
        </LinearLayout>

        <!-- Search bar -->
        <LinearLayout
            android:id="@+id/btnSearch"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingLeft="18dp"
            android:paddingRight="18dp"
            android:background="@drawable/bg_home_search"
            android:focusable="true"
            android:focusableInTouchMode="false"
            android:clickable="true"
            android:nextFocusRight="@id/navSettings"
            android:nextFocusDown="@id/cardLive">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Search"
                android:textSize="13sp"
                android:textColor="#3a4560"/>
        </LinearLayout>

        <!-- Settings button -->
        <LinearLayout
            android:id="@+id/navSettings"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="10dp"
            android:gravity="center"
            android:background="@drawable/bg_home_circle_btn"
            android:focusable="true"
            android:focusableInTouchMode="false"
            android:clickable="true"
            android:nextFocusLeft="@id/btnSearch"
            android:nextFocusRight="@id/btnAvatar"
            android:nextFocusDown="@id/cardSports">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚙"
                android:textSize="16sp"
                android:textColor="#8899aa"/>
        </LinearLayout>

        <!-- Avatar with red ring -->
        <FrameLayout
            android:id="@+id/btnAvatar"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_avatar_btn"
            android:focusable="true"
            android:focusableInTouchMode="false"
            android:clickable="true"
            android:nextFocusLeft="@id/navSettings"
            android:nextFocusDown="@id/cardFilms">

            <LinearLayout
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="center"
                android:gravity="center"
                android:background="@drawable/bg_home_circle_btn">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👤"
                    android:textSize="13sp"/>
            </LinearLayout>
        </FrameLayout>

    </LinearLayout>

    <!-- ══════════ CONTENT AREA ══════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingLeft="40dp"
        android:paddingRight="36dp"
        android:paddingBottom="24dp"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!-- ══════════ WELCOME BLOCK ══════════ -->
        <LinearLayout
            android:id="@+id/welcomeBlock"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_vertical"
            android:alpha="0">

            <TextView
                android:id="@+id/tvWelcomeGreeting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bonjour,"
                android:textSize="17sp"
                android:textColor="#94A3B8"
                android:letterSpacing="0.02"/>

            <TextView
                android:id="@+id/tvWelcomeName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text=""
                android:textSize="58sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:shadowColor="#1E3A8A"
                android:shadowDx="0"
                android:shadowDy="3"
                android:shadowRadius="24"
                android:letterSpacing="-0.02"/>

            <TextView
                android:id="@+id/tvWelcomeSub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Bon visionnage !"
                android:textSize="15sp"
                android:textColor="#64748B"
                android:letterSpacing="0.03"/>

        </LinearLayout>

        <!-- ══════════ CARDS + RIGHT PANEL ══════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:clipChildren="false"
            android:clipToPadding="false">

        <!-- CARDS ROW — all 3 same size -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:clipChildren="false"
            android:clipToPadding="false">

            <!-- ═══ LIVE TV ═══ -->
            <FrameLayout
                android:id="@+id/cardLive"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="260dp"
                android:background="@drawable/bg_home_card"
                android:foreground="@drawable/bg_home_card_focus"
                android:focusable="true"
                android:focusableInTouchMode="false"
                android:clickable="true"
                android:layout_marginEnd="16dp"
                android:nextFocusUp="@id/btnSearch"
                android:nextFocusLeft="@id/cardLive"
                android:nextFocusRight="@id/cardSports">

                <!-- LIVE badge — top right -->
                <LinearLayout
                    android:id="@+id/badgeLiveSports"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|end"
                    android:layout_margin="10dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_live_badge"
                    android:paddingLeft="7dp"
                    android:paddingRight="7dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp"
                    android:visibility="visible">

                    <View
                        android:layout_width="5dp"
                        android:layout_height="5dp"
                        android:background="@drawable/bg_dot_green"
                        android:layout_marginEnd="4dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LIVE"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:textColor="#1a1400"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingBottom="22dp">

                    <LinearLayout
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:gravity="center"
                        android:background="@drawable/bg_home_icon_box">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_home_livetv"
                            android:scaleType="fitCenter"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Live TV's"
                        android:textSize="19sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"/>

                    <TextView
                        android:id="@+id/tvSubtitleLive"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:text="+5000 Channels"
                        android:textSize="12sp"
                        android:textColor="#6b7894"/>
                </LinearLayout>

                <View
                    android:id="@+id/indicatorLive"
                    android:layout_width="34dp"
                    android:layout_height="3dp"
                    android:layout_gravity="bottom|center_horizontal"
                    android:layout_marginBottom="10dp"
                    android:background="#FFFFFF"
                    android:visibility="gone"/>
            </FrameLayout>

            <!-- ═══ SPORTS ═══ -->
            <FrameLayout
                android:id="@+id/cardSports"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="260dp"
                android:background="@drawable/bg_home_card"
                android:foreground="@drawable/bg_home_card_focus"
                android:focusable="true"
                android:focusableInTouchMode="false"
                android:clickable="true"
                android:layout_marginEnd="16dp"
                android:nextFocusUp="@id/navSettings"
                android:nextFocusLeft="@id/cardLive"
                android:nextFocusRight="@id/cardFilms">


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingBottom="22dp">

                    <LinearLayout
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:gravity="center"
                        android:background="@drawable/bg_home_icon_box">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_home_sports"
                            android:scaleType="fitCenter"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Sports"
                        android:textSize="19sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"/>

                    <TextView
                        android:id="@+id/tvSubtitleRadios"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:text="Live Matches"
                        android:textSize="12sp"
                        android:textColor="#6b7894"/>

                </LinearLayout>

                <!-- Infos match — overlay bas de carte, hors du LinearLayout centré -->
                <LinearLayout
                    android:id="@+id/layoutSportInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|center_horizontal"
                    android:layout_marginBottom="22dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tvSportScore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:visibility="gone"/>

                    <TextView
                        android:id="@+id/tvSportMatch"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingLeft="12dp"
                        android:paddingRight="12dp"
                        android:textSize="11sp"
                        android:textColor="#e2e8f0"
                        android:gravity="center"
                        android:maxLines="2"
                        android:ellipsize="end"/>

                    <TextView
                        android:id="@+id/tvSportChannel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textSize="9sp"
                        android:textColor="#94a3b8"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:visibility="gone"/>
                </LinearLayout>

                <View
                    android:id="@+id/indicatorSports"
                    android:layout_width="34dp"
                    android:layout_height="3dp"
                    android:layout_gravity="bottom|center_horizontal"
                    android:layout_marginBottom="10dp"
                    android:background="#FFFFFF"
                    android:visibility="gone"/>
            </FrameLayout>

            <!-- ═══ MOVIES ═══ -->
            <FrameLayout
                android:id="@+id/cardFilms"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="260dp"
                android:background="@drawable/bg_home_card"
                android:foreground="@drawable/bg_home_card_focus"
                android:focusable="true"
                android:focusableInTouchMode="false"
                android:clickable="true"
                android:nextFocusUp="@id/btnAvatar"
                android:nextFocusLeft="@id/cardSports"
                android:nextFocusRight="@id/cardFilms">

                <!-- New badge (orange) -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|end"
                    android:layout_margin="10dp"
                    android:text="New"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="#E07600"
                    android:paddingLeft="8dp"
                    android:paddingRight="8dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingBottom="22dp">

                    <LinearLayout
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:gravity="center"
                        android:background="@drawable/bg_home_icon_box">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_home_movies"
                            android:scaleType="fitCenter"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Movies"
                        android:textSize="19sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"/>

                    <TextView
                        android:id="@+id/tvSubtitleMovies"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:text="VOD Catalog"
                        android:textSize="12sp"
                        android:textColor="#6b7894"/>
                </LinearLayout>

                <View
                    android:id="@+id/indicatorFilms"
                    android:layout_width="34dp"
                    android:layout_height="3dp"
                    android:layout_gravity="bottom|center_horizontal"
                    android:layout_marginBottom="10dp"
                    android:background="#FFFFFF"
                    android:visibility="gone"/>
            </FrameLayout>

        </LinearLayout>

        <!-- RIGHT INFO PANEL: weather + clock + date + MAC -->
        <LinearLayout
            android:layout_width="175dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="☁"
                    android:textSize="15sp"
                    android:textColor="#6b7894"
                    android:layout_marginEnd="5dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="24°"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvClock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="--:--"
                android:textSize="56sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:fontFamily="monospace"
                android:letterSpacing="0.02"/>

            <TextView
                android:id="@+id/tvDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="..."
                android:textSize="12sp"
                android:textColor="#6b7894"
                android:gravity="center"
                android:layout_marginTop="2dp"/>

            <TextView
                android:id="@+id/tvUserName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:maxLines="1"
                android:ellipsize="end"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/tvExpiry"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:textSize="10sp"
                android:textColor="#6b7894"
                android:gravity="center"
                android:maxLines="1"
                android:visibility="gone"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#191f30"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:id="@+id/tvMacFooter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="MAC: —"
                android:textSize="9sp"
                android:textColor="#252e3d"
                android:gravity="center"
                android:fontFamily="monospace"/>

            <TextView
                android:id="@+id/tvVersionFooter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="6dp"
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="#1e2a3a"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:background="@drawable/bg_version_badge"
                android:fontFamily="monospace"/>

        </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
