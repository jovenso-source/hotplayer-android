<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#070809">

    <!-- ══ MAIN HUB ══ -->
    <LinearLayout
        android:id="@+id/layoutHub"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="visible">

        <!-- ─ TOP BAR ─ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="24dp"
            android:background="#0d0f12">

            <Button
                android:id="@+id/btnBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="←"
                android:textSize="16sp"
                android:textColor="#94a3b8"
                android:backgroundTint="#1a1f2e"
                android:focusable="true"
                android:layout_marginEnd="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SPORT"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:letterSpacing="0.1"/>

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>

            <!-- Live count badge -->
            <TextView
                android:id="@+id/tvLiveBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_live_badge"
                android:visibility="gone"/>
        </LinearLayout>

        <!-- ─ SCROLL CONTENT ─ -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="20dp">

                <!-- ── SECTION: EN DIRECT ──────────────────────────── -->
                <LinearLayout
                    android:id="@+id/sectionLive"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="20dp">

                    <!-- Section header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="24dp"
                        android:paddingBottom="12dp">

                        <View
                            android:layout_width="3dp"
                            android:layout_height="18dp"
                            android:background="#e53935"
                            android:layout_marginEnd="10dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="EN DIRECT"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:letterSpacing="0.08"/>

                        <TextView
                            android:id="@+id/tvLiveCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:paddingHorizontal="7dp"
                            android:paddingVertical="2dp"
                            android:textSize="10sp"
                            android:textColor="#e53935"
                            android:background="#1ae53935"
                            android:visibility="gone"/>
                    </LinearLayout>

                    <!-- Live matches horizontal list -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvLive"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="24dp"
                        android:clipToPadding="false"
                        android:descendantFocusability="afterDescendants"
                        android:orientation="horizontal"/>

                    <!-- Empty state -->
                    <TextView
                        android:id="@+id/tvNoLive"
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:text="Aucun match en direct pour le moment"
                        android:textSize="13sp"
                        android:textColor="#2a3244"
                        android:gravity="center"
                        android:visibility="gone"/>
                </LinearLayout>

                <!-- ── SECTION: CATÉGORIES ────────────────────────── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="24dp">

                    <!-- Section header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="24dp"
                        android:paddingBottom="12dp">

                        <View
                            android:layout_width="3dp"
                            android:layout_height="18dp"
                            android:background="#ff4d00"
                            android:layout_marginEnd="10dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CATÉGORIES"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:letterSpacing="0.08"/>
                    </LinearLayout>

                    <!-- Category cards horizontal list -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvCategories"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="24dp"
                        android:clipToPadding="false"
                        android:descendantFocusability="afterDescendants"
                        android:orientation="horizontal"/>
                </LinearLayout>

                <!-- ── SECTION: À VENIR ──────────────────────────── -->
                <LinearLayout
                    android:id="@+id/sectionUpcoming"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="24dp">

                    <!-- Section header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="24dp"
                        android:paddingBottom="12dp">

                        <View
                            android:layout_width="3dp"
                            android:layout_height="18dp"
                            android:background="#3d7eff"
                            android:layout_marginEnd="10dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="À VENIR"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:letterSpacing="0.08"/>

                        <TextView
                            android:id="@+id/tvUpcomingCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:paddingHorizontal="7dp"
                            android:paddingVertical="2dp"
                            android:textSize="10sp"
                            android:textColor="#3d7eff"
                            android:background="#1a3d7eff"
                            android:visibility="gone"/>
                    </LinearLayout>

                    <!-- Upcoming events horizontal list -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvUpcoming"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="24dp"
                        android:clipToPadding="false"
                        android:descendantFocusability="afterDescendants"
                        android:orientation="horizontal"/>
                </LinearLayout>

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <!-- ══ MATCH DETAIL OVERLAY ══ -->
    <LinearLayout
        android:id="@+id/layoutDetail"
        android:layout_width="480dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:orientation="vertical"
        android:background="#f0070809"
        android:visibility="gone"
        android:elevation="8dp">

        <!-- Detail header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:background="#0d0f12">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Regarder"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"/>

            <Button
                android:id="@+id/btnCloseDetail"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:text="✕"
                android:textSize="12sp"
                android:textColor="#94a3b8"
                android:backgroundTint="#1a1f2e"
                android:focusable="true"/>
        </LinearLayout>

        <!-- Match detail card -->
        <LinearLayout
            android:id="@+id/layoutMatchDetail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#0f1520"
            android:padding="18dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:id="@+id/ivDetailLogo"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginEnd="8dp"
                    android:scaleType="fitCenter"/>

                <TextView
                    android:id="@+id/tvDetailLeague"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="11sp"
                    android:textColor="#4a5670"
                    android:maxLines="1"
                    android:ellipsize="end"/>

                <TextView
                    android:id="@+id/tvDetailStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="2dp"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_live_badge"/>
            </LinearLayout>

            <!-- Teams + score -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvDetailHome"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:maxLines="2"/>

                <TextView
                    android:id="@+id/tvDetailScore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="14dp"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:fontFamily="monospace"/>

                <TextView
                    android:id="@+id/tvDetailAway"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:gravity="end"
                    android:maxLines="2"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Channels header -->
        <TextView
            android:id="@+id/tvChannelsHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📺  CHAÎNES DISPONIBLES"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#3d4a5c"
            android:letterSpacing="0.1"
            android:paddingHorizontal="18dp"
            android:paddingTop="16dp"
            android:paddingBottom="8dp"/>

        <!-- Channel list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvChannels"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:descendantFocusability="afterDescendants"/>

        <!-- No channels -->
        <LinearLayout
            android:id="@+id/layoutNoChannels"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📡"
                android:textSize="30sp"/>
            <TextView
                android:id="@+id/tvNoChannelsMsg"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Aucune chaîne trouvée"
                android:textSize="13sp"
                android:textColor="#2a3244"
                android:gravity="center"/>
        </LinearLayout>
    </LinearLayout>

    <!-- ══ LOADING OVERLAY ══ -->
    <LinearLayout
        android:id="@+id/layoutLoading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#CC070809">

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:indeterminateTint="#ff4d00"/>

        <TextView
            android:id="@+id/tvError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:paddingHorizontal="60dp"
            android:textSize="13sp"
            android:textColor="#94a3b8"
            android:gravity="center"
            android:lineSpacingMultiplier="1.5"
            android:visibility="gone"/>

        <Button
            android:id="@+id/btnRetry"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginTop="20dp"
            android:text="Réessayer"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#ff4d00"
            android:visibility="gone"
            android:focusable="true"/>
    </LinearLayout>

</FrameLayout>
