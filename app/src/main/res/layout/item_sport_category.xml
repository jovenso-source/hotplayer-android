<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="220dp"
    android:layout_height="155dp"
    android:layout_marginEnd="12dp"
    android:focusable="true"
    android:clickable="true"
    android:foreground="?android:attr/selectableItemBackground">

    <!-- Gradient background (set via code) -->
    <View
        android:id="@+id/viewBg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_sport_football"/>

    <!-- Shine overlay (top-left corner accent) -->
    <View
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_gravity="top|end"
        android:background="#12ffffff"
        android:rotation="45"/>

    <!-- Large emoji watermark -->
    <TextView
        android:id="@+id/tvSportEmojiBig"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="14dp"
        android:textSize="52sp"
        android:alpha="0.35"
        android:text="⚽"/>

    <!-- Live matches badge (top-left) -->
    <TextView
        android:id="@+id/tvMatchCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_margin="10dp"
        android:paddingHorizontal="7dp"
        android:paddingVertical="2dp"
        android:textSize="10sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:background="@drawable/bg_live_badge"
        android:visibility="gone"/>

    <!-- Bottom info panel -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingBottom="14dp"
        android:paddingTop="30dp"
        android:background="#CC000000">

        <!-- Sport name -->
        <TextView
            android:id="@+id/tvSportName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:text="Football"/>

        <!-- Channel count -->
        <TextView
            android:id="@+id/tvChannelCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textSize="11sp"
            android:textColor="#94a3b8"
            android:text="0 chaînes"/>
    </LinearLayout>

    <!-- Focus border overlay -->
    <View
        android:id="@+id/viewFocusBorder"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_sport_card_focused"
        android:visibility="gone"/>
</FrameLayout>
