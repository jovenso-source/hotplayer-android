<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="100dp"
    android:orientation="horizontal"
    android:layout_marginLeft="7dp"
    android:layout_marginRight="7dp"
    android:layout_marginTop="3dp"
    android:layout_marginBottom="3dp"
    android:focusable="true"
    android:focusableInTouchMode="false"
    android:clickable="true"
    android:background="@drawable/bg_ch_item">

    <!-- Channel logo — square, full card height, dark bg -->
    <FrameLayout
        android:layout_width="88dp"
        android:layout_height="match_parent"
        android:background="#0D1020">

        <!-- Fallback text logo -->
        <TextView
            android:id="@+id/tvChLogo"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_logo_icon"/>

        <!-- Image logo (centered, scale to fit) -->
        <ImageView
            android:id="@+id/ivChLogo"
            android:layout_width="68dp"
            android:layout_height="68dp"
            android:layout_gravity="center"
            android:scaleType="centerInside"
            android:visibility="gone"/>
    </FrameLayout>

    <!-- Info panel -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingLeft="14dp"
        android:paddingRight="12dp"
        android:paddingTop="12dp"
        android:paddingBottom="10dp">

        <!-- Row 1: Name + Quality badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvChName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/tvChQuality"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#00A8FF"
                android:background="@drawable/bg_quality_badge"
                android:paddingLeft="5dp"
                android:paddingRight="5dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:layout_marginStart="6dp"
                android:visibility="gone"/>
        </LinearLayout>

        <!-- Row 2: EPG program text (fills remaining height) -->
        <TextView
            android:id="@+id/tvChEpg"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:textSize="12sp"
            android:textColor="#64748B"
            android:maxLines="1"
            android:ellipsize="end"
            android:gravity="center_vertical"/>

        <!-- Row 3: Progress bar + channel number + live dot -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ProgressBar
                android:id="@+id/pbChEpg"
                android:layout_width="0dp"
                android:layout_height="2dp"
                android:layout_weight="1"
                style="?android:attr/progressBarStyleHorizontal"
                android:progress="0"
                android:max="100"
                android:progressTint="#00A8FF"
                android:progressBackgroundTint="#1E2436"/>

            <TextView
                android:id="@+id/tvChNum"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="#4A5670"
                android:fontFamily="monospace"
                android:layout_marginStart="8dp"/>

            <View
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:background="@drawable/bg_dot_green"
                android:layout_marginStart="6dp"/>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
