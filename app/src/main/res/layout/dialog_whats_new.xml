<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center">

    <LinearLayout
        android:layout_width="460dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:background="@drawable/bg_popup_card"
        android:padding="32dp"
        android:gravity="center_horizontal">

        <!-- Emoji -->
        <TextView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:gravity="center"
            android:text="🎉"
            android:textSize="34sp"
            android:background="@drawable/bg_logo_card"
            android:layout_marginBottom="24dp"/>

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bienvenue sur Freebox !"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:layout_marginBottom="8dp"/>

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Merci d'avoir choisi Freebox."
            android:textSize="14sp"
            android:textColor="#f5a623"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="20dp"/>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1a2235"
            android:layout_marginBottom="20dp"/>

        <!-- Description -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Accédez facilement à vos chaînes préférées et profitez d'une expérience TV simple, rapide et fluide.\n\nNous vous souhaitons une excellente expérience de visionnage."
            android:textSize="13sp"
            android:textColor="#e2e8f0"
            android:lineSpacingExtra="4dp"
            android:gravity="center"
            android:layout_marginBottom="28dp"/>

        <!-- Button -->
        <Button
            android:id="@+id/btnClose"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Commencer"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#ff4d00"
            android:focusable="true"/>
    </LinearLayout>

</FrameLayout>
