# ─── Serveur ──────────────────────────────────────────
PORT=3000

# ─── PostgreSQL ───────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hotplayer
DB_USER=postgres
DB_PASSWORD=your_password_here

# ─── JWT ──────────────────────────────────────────────
# Générer avec : openssl rand -hex 64
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_64_BYTE_HEX_STRING
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES=30d

# ─── Sécurité ─────────────────────────────────────────
# Fenêtre anti-replay en secondes (défaut : 300 = ±5 min)
SIGNATURE_WINDOW_SECS=300
# Nombre de nonces conservés par session
MAX_NONCES=100
# Score de risque au-delà duquel l'appareil est suspendu (0-100)
AUTO_SUSPEND_SCORE=80
# Nombre max d'appareils par utilisateur (par défaut)
DEFAULT_MAX_DEVICES=1

# ─── CORS ─────────────────────────────────────────────
# Laisser vide = accepte tout (adapter en production)
ALLOWED_ORIGINS=
